{
  "id": "cc",
  "name": "Claude",
  "aliases": [
    "claude",
    "cc"
  ],
  "displayName": "Claude Code",
  "shortName": "CC",
  "providerFamily": "anthropic",
  "portOffset": 1,
  "terminalColor": "blue",
  "bannerColor": "#3B82F6",
  "defaultFleetAgent": true,
  "installHint": "brew install claude  (or: npm i -g @anthropic-ai/claude-code)",
  "installCommand": "npm i -g @anthropic-ai/claude-code",
  "trust": {
    "type": "claude-json",
    "path": "~/.claude.json",
    "projectKey": "hasTrustDialogAccepted"
  },
  "worktreeEnv": {},
  "git": {
    "hasEmailAttribution": true
  },
  "capabilities": {
    "supportsModelFlag": true,
    "transcriptTelemetry": true,
    "resolvesSlashCommands": true
  },
  "cli": {
    "command": "claude",
    "implementFlag": "--permission-mode acceptEdits",
    "implementPrompt": "/aigon:feature-do {featureId}",
    "evalPrompt": "/aigon:feature-eval {featureId}",
    "reviewPrompt": "/aigon:feature-code-review {featureId}",
    "reviewCheckPrompt": "/aigon:feature-code-revise {featureId}",
    "models": {
      "research": "opus",
      "implement": "sonnet",
      "evaluate": "opus",
      "review": "opus"
    },
    "modelOptions": [
      { "value": null, "label": "Default" },
      { "value": "claude-haiku-4-5-20251001", "label": "Haiku 4.5 (fast/cheap)" },
      { "value": "claude-sonnet-4-6", "label": "Sonnet 4.6" },
      { "value": "claude-sonnet-4-6[1m]", "label": "Sonnet 4.6 (1M context)" },
      { "value": "claude-opus-4-7", "label": "Opus 4.7" },
      { "value": "claude-opus-4-7[1m]", "label": "Opus 4.7 (1M context)" }
    ],
    "effortOptions": [
      { "value": null, "label": "Default" },
      { "value": "low", "label": "Low" },
      { "value": "medium", "label": "Medium" },
      { "value": "high", "label": "High" },
      { "value": "xhigh", "label": "Extra-high" }
    ],
    "complexityDefaults": {
      "low":       { "model": "claude-haiku-4-5-20251001", "effort": "low" },
      "medium":    { "model": "claude-sonnet-4-6",          "effort": "medium" },
      "high":      { "model": "claude-sonnet-4-6[1m]",      "effort": "high" },
      "very-high": { "model": "claude-opus-4-7[1m]",        "effort": "xhigh" }
    },
    "modelFlag": "--model",
    "effortFlag": "--effort",
    "effortEnv": null,
    "submitKey": "Enter"
  },
  "placeholders": {
    "AGENT_ID": "cc",
    "AGENT_NAME": "Claude",
    "AGENT_TITLE": "Claude Code Configuration",
    "ARG_SYNTAX": "{{args}}",
    "ARG1_SYNTAX": "{{args}}",
    "CMD_PREFIX": "/aigon:",
    "AGENT_TEAMS_RESEARCH_NOTE": "\n### Agent Teams (optional)\n\nFor complex research topics with multiple questions, consider creating an agent team. Spawn teammates to investigate different questions in parallel with adversarial debate \u2014 have them challenge each other's findings. Use delegate mode so you coordinate without researching yourself. Reference: https://code.claude.com/docs/en/agent-teams\n",
    "AGENT_TEAMS_FEATURE_NOTE": "\n### Agent Teams (optional)\n\nFor features with multiple independent acceptance criteria spanning different areas (e.g., frontend, backend, tests), consider creating an agent team. Assign each teammate a distinct slice of the implementation with clear file ownership boundaries to avoid conflicts. Use delegate mode and require plan approval before teammates begin implementing. Reference: https://code.claude.com/docs/en/agent-teams\n",
    "AGENT_DEV_SERVER_NOTE": "",
    "AGENT_PITFALLS": "",
    "PERMISSION_SAVE_NOTE": "\n## Saving Permissions\n\nWhen the user says \"save that permission\", \"remember that\", or asks you to persist a permission you were just granted:\n\n1. Read `.claude/settings.json`\n2. Add the tool pattern to the `permissions.allow` array\n3. Write the updated file\n4. Confirm what you saved\n\nUse the narrowest pattern that covers the user's intent:\n- Specific: `Bash(npm test)`, `Bash(git push:*)`\n- Broad: `Bash(npm:*)`, `Bash(node:*)`\n\nPrefer specific patterns \u2014 broad Bash allows can be chained to bypass deny rules. Ask the user if unsure whether to save narrowly or broadly.\n"
  },
  "output": {
    "format": "markdown",
    "commandDir": ".claude/commands/aigon",
    "commandFilePrefix": "",
    "commandFileExtension": ".md",
    "frontmatter": [
      "description",
      "argument-hint",
      "disable-model-invocation"
    ]
  },
  "rootFile": null,
  "supportsAgentsMd": false,
  "agentFile": "claude.md",
  "templatePath": "generic/docs/agent.md",
  "extras": {
    "skill": {
      "enabled": true,
      "path": ".claude/skills/aigon/SKILL.md"
    },
    "settings": {
      "enabled": true,
      "path": ".claude/settings.json",
      "permissions": [
        "Bash(aigon:*)",
        "Bash(npm install*)",
        "Bash(npm ci*)",
        "Bash(npm run *)",
        "Bash(npm test*)",
        "Bash(npx *)",
        "Bash(pnpm install*)",
        "Bash(pnpm run *)",
        "Bash(pnpm *)",
        "Bash(yarn install*)",
        "Bash(yarn *)",
        "Bash(bun install*)",
        "Bash(bun run *)",
        "Bash(node *)",
        "Bash(git add*)",
        "Bash(git commit*)",
        "Bash(git checkout*)",
        "Bash(git push*)",
        "Bash(git pull*)",
        "Bash(git fetch*)",
        "Bash(git status*)",
        "Bash(git diff*)",
        "Bash(git log*)",
        "Bash(git stash*)",
        "Bash(git rebase*)",
        "Bash(git merge*)",
        "Bash(curl *)",
        "Bash(cat *)",
        "Bash(ls*)",
        "Bash(find *)",
        "Bash(grep *)",
        "Bash(mkdir *)",
        "Bash(cp *)",
        "Bash(mv *)",
        "Bash(touch *)",
        "Bash(echo *)",
        "Bash(pwd)",
        "Bash(which *)",
        "Bash(head *)",
        "Bash(tail *)"
      ],
      "denyPermissions": [
        "Bash(rm -rf /)",
        "Bash(rm -rf ~)",
        "Bash(sudo:*)",
        "Bash(su:*)"
      ],
      "hooks": {
        "SessionStart": [
          {
            "matcher": "startup",
            "hooks": [
              {
                "type": "command",
                "command": "aigon check-version",
                "timeout": 30
              },
              {
                "type": "command",
                "command": "aigon project-context",
                "timeout": 10
              }
            ]
          }
        ],
        "SessionEnd": [
          {
            "matcher": ".*",
            "hooks": [
              {
                "type": "command",
                "command": "aigon capture-session-telemetry",
                "timeout": 30
              }
            ]
          }
        ],
        "Stop": [
          {
            "matcher": ".*",
            "hooks": [
              {
                "type": "command",
                "command": "aigon check-agent-submitted",
                "timeout": 5
              }
            ]
          }
        ]
      }
    }
  },
  "signals": {
    "shellTrap": true,
    "heartbeatSidecar": true,
    "cliHooks": {
      "heartbeatTouch": "PostToolUse",
      "exitEnforcement": "Stop"
    }
  },
  "failureDetectors": {
    "tokenExhaustion": {
      "exitCodes": [1],
      "stderrPatterns": [
        "usage limit",
        "quota exceeded",
        "credit balance",
        "context window",
        "rate limit"
      ]
    }
  },
  "commandExcludes": []
}
