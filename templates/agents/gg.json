{
  "id": "gg",
  "name": "Gemini",
  "aliases": [
    "gemini",
    "gg"
  ],
  "cli": {
    "command": "gemini",
    "implementFlag": "--yolo",
    "implementPrompt": "/aigon:feature-do {featureId}",
    "evalPrompt": "/aigon:feature-eval {featureId}",
    "models": {
      "research": "gemini-3.1-pro-preview",
      "implement": "gemini-3-flash-preview",
      "evaluate": "gemini-3.1-pro-preview"
    }
  },
  "placeholders": {
    "AGENT_ID": "gg",
    "AGENT_NAME": "Gemini",
    "AGENT_TITLE": "Gemini CLI Configuration",
    "ARG_SYNTAX": "{{args}}",
    "ARG1_SYNTAX": "{{args}}",
    "CMD_PREFIX": "/aigon:",
    "AGENT_TEAMS_RESEARCH_NOTE": "",
    "AGENT_TEAMS_FEATURE_NOTE": "",
    "AGENT_DEV_SERVER_NOTE": "",
    "PERMISSION_SAVE_NOTE": "\n## Saving Permissions\n\nWhen the user says \"save that permission\" or \"remember that\":\n\n1. Read or create a TOML file in `.gemini/policies/` (e.g., `.gemini/policies/custom.toml`)\n2. Add a `[[rule]]` block with the tool name, decision, and priority\n3. Example:\n   ```toml\n   [[rule]]\n   toolName = \"run_shell_command\"\n   commandPrefix = \"npm\"\n   decision = \"allow\"\n   priority = 100\n   ```\n\nNote: The old `allowedTools` array in settings.json is deprecated. Use Policy Engine TOML files instead.\n"
  },
  "output": {
    "format": "toml",
    "commandDir": ".gemini/commands/aigon",
    "commandFilePrefix": "",
    "commandFileExtension": ".toml"
  },
  "rootFile": null,
  "supportsAgentsMd": true,
  "agentFile": "gemini.md",
  "templatePath": "generic/docs/agent.md",
  "extras": {
    "settings": {
      "enabled": true,
      "path": ".gemini/settings.json",
      "policies": [
        {
          "toolName": "run_shell_command",
          "commandPrefix": "aigon",
          "decision": "allow",
          "priority": 100
        },
        {
          "toolName": "run_shell_command",
          "commandPrefix": "node",
          "argsPattern": "aigon-cli\\.js",
          "decision": "allow",
          "priority": 100
        }
      ],
      "hooks": {
        "SessionStart": [
          {
            "matcher": "startup",
            "hooks": [
              {
                "type": "command",
                "command": "aigon check-version",
                "timeout": 30
              },
              {
                "type": "command",
                "command": "aigon project-context",
                "timeout": 10
              }
            ]
          }
        ]
      }
    }
  },
  "commands": [
    "feature-create",
    "feature-now",
    "feature-prioritise",
    "feature-setup",
    "feature-do",
    "feature-submit",
    "feature-eval",
    "feature-review",
    "feature-close",
    "feature-cleanup",
    "feature-autopilot",
    "board",
    "feature-open",
    "sessions-close",
    "research-create",
    "research-prioritise",
    "research-setup",
    "research-open",
    "research-do",
    "research-submit",
    "research-synthesize",
    "research-close",
    "research-autopilot",
    "feedback-create",
    "feedback-list",
    "feedback-triage",
    "dev-server",
    "help",
    "next"
  ]
}
