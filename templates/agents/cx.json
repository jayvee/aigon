{
  "id": "cx",
  "name": "Codex",
  "aliases": [
    "codex",
    "cx"
  ],
  "displayName": "Codex",
  "shortName": "CX",
  "providerFamily": "openai",
  "portOffset": 3,
  "terminalColor": "magenta",
  "bannerColor": "#A855F7",
  "defaultFleetAgent": false,
  "installHint": "npm i -g @openai/codex",
  "installCommand": "npm i -g @openai/codex",
  "trust": {
    "type": "toml-project",
    "path": "~/.codex/config.toml",
    "trustLevel": "trusted"
  },
  "worktreeEnv": {},
  "legacy": {
    "promptFile": ".codex/prompt.md"
  },
  "git": {
    "hasEmailAttribution": true
  },
  "capabilities": {
    "supportsModelFlag": true,
    "transcriptTelemetry": true,
    "resolvesSlashCommands": false
  },
  "cli": {
    "command": "codex",
    "implementFlag": "",
    "implementPrompt": "feature-do",
    "evalPrompt": "feature-eval",
    "reviewPrompt": "feature-code-review",
    "reviewCheckPrompt": "feature-code-revise",
    "models": {
      "research": "gpt-5.4-mini",
      "implement": "gpt-5.5",
      "evaluate": "gpt-5.5",
      "review": "gpt-5.5"
    },
    "modelOptions": [
      { "value": null, "label": "Default" },
      { "value": "gpt-5.5", "label": "GPT-5.5" },
      { "value": "gpt-5.4", "label": "GPT-5.4" },
      { "value": "gpt-5.4-mini", "label": "GPT-5.4 Mini" },
      { "value": "gpt-5.3-codex", "label": "GPT-5.3 Codex" },
      { "value": "gpt-5.2", "label": "GPT-5.2" }
    ],
    "effortOptions": [
      { "value": null, "label": "Default" },
      { "value": "minimal", "label": "Minimal" },
      { "value": "low", "label": "Low" },
      { "value": "medium", "label": "Medium" },
      { "value": "high", "label": "High" }
    ],
    "complexityDefaults": {
      "low":       { "model": "gpt-5.4-mini",  "effort": "low" },
      "medium":    { "model": "gpt-5.5",        "effort": "medium" },
      "high":      { "model": "gpt-5.5",        "effort": "high" },
      "very-high": { "model": "gpt-5.5",        "effort": "high" }
    },
    "modelFlag": "--model",
    "effortFlag": "-c model_reasoning_effort=",
    "effortEnv": null,
    "submitKey": "Enter"
  },
  "placeholders": {
    "AGENT_ID": "cx",
    "AGENT_NAME": "Codex",
    "AGENT_TITLE": "Codex Configuration",
    "ARG_SYNTAX": "$ARGUMENTS",
    "ARG1_SYNTAX": "$1",
    "CMD_PREFIX": "$aigon-",
    "AGENT_TEAMS_RESEARCH_NOTE": "",
    "AGENT_TEAMS_FEATURE_NOTE": "",
    "PERMISSION_SAVE_NOTE": "",
    "AGENT_PITFALLS": "",
    "AGENT_DEV_SERVER_NOTE": "\n> **CRITICAL \u2014 Codex dev server rules:**\n>\n> **NEVER run `npm run dev`, `next dev`, or any dev command directly.** Running dev commands directly bypasses port allocation and will cause port conflicts.\n>\n> The PORT is already set in `.env.local` by the worktree setup. If you must start a dev server, use `aigon dev-server start`.\n>\n> Because Codex kills background processes when shell commands exit, use `--register-only` mode:\n>\n> 1. Run `aigon dev-server start --register-only` \u2014 allocates your agent's port and writes it to `.env.local`\n> 2. Read the allocated port: `grep ^PORT= .env.local`\n> 3. Start the server in a **persistent terminal session** using `/terminal`: `PORT=<the-port> npm run dev`\n> 4. Get your app URL: `aigon dev-server url`\n> 5. Use that URL for all testing\n"
  },
  "output": {
    "format": "skill-md",
    "commandDir": ".agents/skills",
    "commandFilePrefix": "aigon-",
    "commandFileExtension": "",
    "skillFileName": "SKILL.md",
    "frontmatter": [
      "name",
      "description"
    ],
    "global": false
  },
  "rootFile": null,
  "supportsAgentsMd": true,
  "agentFile": "codex.md",
  "templatePath": "generic/docs/agent.md",
  "extras": {
    "prompt": {
      "enabled": false,
      "path": ".codex/prompt.md"
    },
    "config": {
      "enabled": true,
      "path": ".codex/config.toml"
    }
  },
  "signals": {
    "shellTrap": true,
    "heartbeatSidecar": true,
    "cliHooks": null
  },
  "failureDetectors": {
    "tokenExhaustion": {
      "exitCodes": [1, 2],
      "stderrPatterns": [
        "token limit",
        "token budget",
        "quota exceeded",
        "usage limit",
        "rate limit exceeded",
        "insufficient credits",
        "context length"
      ]
    }
  },
  "idleDetection": {
    "_todo": "no reliable Codex CLI idle pattern confirmed yet — leave absent so supervisor skips capture-pane"
  },
  "commandExcludes": []
}
