{
  "id": "cu",
  "name": "Cursor",
  "aliases": [
    "cursor",
    "cu"
  ],
  "displayName": "Cursor",
  "providerFamily": "varies",
  "portOffset": 4,
  "defaultFleetAgent": false,
  "installHint": "Download from https://cursor.com",
  "trust": null,
  "worktreeEnv": {},
  "git": {
    "hasEmailAttribution": true
  },
  "capabilities": {
    "supportsModelFlag": false,
    "transcriptTelemetry": false
  },
  "legacy": {
    "rootFile": null,
    "promptFile": null
  },
  "cli": {
    "command": "agent",
    "implementFlag": "--force",
    "implementPrompt": "/aigon-feature-do {featureId}",
    "evalPrompt": "/aigon-feature-eval {featureId}",
    "reviewPrompt": "/aigon-feature-review {featureId}",
    "models": {}
  },
  "placeholders": {
    "AGENT_ID": "cu",
    "AGENT_NAME": "Cursor",
    "AGENT_TITLE": "Cursor Configuration",
    "ARG_SYNTAX": "<args>",
    "ARG1_SYNTAX": "<name>",
    "CMD_PREFIX": "/aigon-",
    "AGENT_TEAMS_RESEARCH_NOTE": "",
    "AGENT_TEAMS_FEATURE_NOTE": "",
    "AGENT_DEV_SERVER_NOTE": "\n> **CRITICAL — Cursor dev server rules:**\n>\n> **NEVER run `npm run dev`, `next dev`, or any dev command directly.** Running dev commands directly bypasses port allocation and will cause port conflicts.\n>\n> Always use `aigon dev-server start` which allocates a unique port and registers with the proxy.\n> Check your URL with `aigon dev-server url`.\n",
    "AGENT_PITFALLS": "",
    "PERMISSION_SAVE_NOTE": ""
  },
  "output": {
    "format": "plain",
    "commandDir": ".cursor/commands",
    "commandFilePrefix": "aigon-",
    "commandFileExtension": ".md",
    "frontmatter": []
  },
  "rootFile": null,
  "supportsAgentsMd": true,
  "agentFile": "cursor.md",
  "templatePath": "generic/docs/agent.md",
  "extras": {
    "settings": {
      "enabled": true,
      "path": ".cursor/cli.json",
      "permissions": [
        "Shell(aigon:*)"
      ]
    },
    "hooks": {
      "enabled": true,
      "path": ".cursor/hooks.json",
      "content": {
        "hooks": {
          "sessionStart": [
            {
              "command": "aigon check-version",
              "timeout": 30
            },
            {
              "command": "aigon project-context",
              "timeout": 10
            }
          ]
        }
      }
    },
    "rules": {
      "enabled": true,
      "path": ".cursor/rules/aigon.mdc"
    }
  },
  "signals": {
    "shellTrap": true,
    "heartbeatSidecar": true,
    "cliHooks": null
  },
  "commands": [
    "feature-create",
    "feature-now",
    "feature-prioritise",
    "feature-start",
    "feature-do",
    "feature-submit",
    "feature-eval",
    "feature-review",
    "feature-close",
    "feature-cleanup",
    "feature-autopilot",
    "board",
    "feature-open",
    "sessions-close",
    "research-create",
    "research-prioritise",
    "research-start",
    "research-open",
    "research-do",
    "research-submit",
    "research-eval",
    "research-close",
    "research-autopilot",
    "feedback-create",
    "feedback-list",
    "feedback-triage",
    "dev-server",
    "help",
    "next"
  ]
}
