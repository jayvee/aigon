{
  "id": "cu",
  "name": "Cursor",
  "aliases": [
    "cursor",
    "cu"
  ],
  "displayName": "Cursor",
  "shortName": "CU",
  "providerFamily": "varies",
  "portOffset": 4,
  "terminalColor": "yellow",
  "bannerColor": "#F97316",
  "defaultFleetAgent": false,
  "installHint": "Download from https://cursor.com",
  "installCommand": null,
  "trust": {
    "type": "vscode-settings-bool",
    "path": "~/Library/Application Support/Cursor/User/settings.json",
    "key": "security.workspace.trust.enabled",
    "value": false
  },
  "worktreeEnv": {},
  "git": {
    "hasEmailAttribution": true
  },
  "capabilities": {
    "supportsModelFlag": false,
    "transcriptTelemetry": false,
    "resolvesSlashCommands": true
  },
  "legacy": {
    "rootFile": null,
    "promptFile": null
  },
  "cli": {
    "command": "agent",
    "implementFlag": "--print --force --trust",
    "implementPrompt": "/aigon-feature-do {featureId}",
    "evalPrompt": "/aigon-feature-eval {featureId}",
    "reviewPrompt": "/aigon-feature-code-review {featureId}",
    "reviewCheckPrompt": "/aigon-feature-code-revise {featureId}",
    "models": {
      "review": "composer-2"
    },
    "modelOptions": [],
    "effortOptions": [],
    "complexityDefaults": {
      "low":       { "model": null, "effort": null },
      "medium":    { "model": null, "effort": null },
      "high":      { "model": null, "effort": null },
      "very-high": { "model": null, "effort": null }
    },
    "modelFlag": null,
    "effortFlag": null,
    "effortEnv": null,
    "submitKey": null
  },
  "placeholders": {
    "AGENT_ID": "cu",
    "AGENT_NAME": "Cursor",
    "AGENT_TITLE": "Cursor Configuration",
    "ARG_SYNTAX": "<args>",
    "ARG1_SYNTAX": "<name>",
    "CMD_PREFIX": "/aigon-",
    "AGENT_TEAMS_RESEARCH_NOTE": "",
    "AGENT_TEAMS_FEATURE_NOTE": "",
    "AGENT_DEV_SERVER_NOTE": "\n> **CRITICAL — Cursor dev server rules:**\n>\n> **NEVER run `npm run dev`, `next dev`, or any dev command directly.** Running dev commands directly bypasses port allocation and will cause port conflicts.\n>\n> Always use `aigon dev-server start` which allocates a unique port and registers with the proxy.\n> Check your URL with `aigon dev-server url`.\n",
    "AGENT_PITFALLS": "",
    "PERMISSION_SAVE_NOTE": ""
  },
  "output": {
    "format": "plain",
    "commandDir": ".cursor/commands",
    "commandFilePrefix": "aigon-",
    "commandFileExtension": ".md",
    "frontmatter": []
  },
  "rootFile": null,
  "supportsAgentsMd": true,
  "agentFile": "cursor.md",
  "templatePath": "generic/docs/agent.md",
  "extras": {
    "settings": {
      "enabled": true,
      "path": ".cursor/cli.json",
      "permissions": [
        "Shell(aigon:*)"
      ]
    },
    "hooks": {
      "enabled": true,
      "path": ".cursor/hooks.json",
      "content": {
        "hooks": {
          "sessionStart": [
            {
              "command": "aigon check-version",
              "timeout": 30
            },
            {
              "command": "aigon project-context",
              "timeout": 10
            }
          ]
        }
      }
    },
    "rules": {
      "enabled": true,
      "path": ".cursor/rules/aigon.mdc"
    }
  },
  "signals": {
    "shellTrap": true,
    "heartbeatSidecar": true,
    "cliHooks": null
  },
  "failureDetectors": {
    "tokenExhaustion": {
      "exitCodes": [1],
      "stderrPatterns": [
        "quota exceeded",
        "token limit",
        "rate limit",
        "insufficient credits"
      ]
    }
  },
  "commandExcludes": []
}
