{
  "id": "cu",
  "name": "Cursor",
  "aliases": [
    "cursor",
    "cu"
  ],
  "displayName": "Cursor",
  "shortName": "CU",
  "providerFamily": "varies",
  "portOffset": 4,
  "terminalColor": "yellow",
  "bannerColor": "#F97316",
  "defaultFleetAgent": false,
  "installHint": "Download from https://cursor.com",
  "installCommand": null,
  "authCheck": {
    "method": "none",
    "loginHint": "Auth managed by Cursor IDE"
  },
  "trust": {
    "type": "vscode-settings-bool",
    "path": "~/Library/Application Support/Cursor/User/settings.json",
    "key": "security.workspace.trust.enabled",
    "value": false,
    "cursorProjectsRoot": "~/.cursor/projects"
  },
  "worktreeEnv": {},
  "git": {
    "hasEmailAttribution": true
  },
  "capabilities": {
    "supportsModelFlag": true,
    "transcriptTelemetry": false,
    "resolvesSlashCommands": true
  },
  "runtime": {
    "telemetryStrategy": "no-telemetry-cursor",
    "trustInstallScope": "worktree-base"
  },
  "legacy": {
    "rootFile": null,
    "promptFile": null
  },
