    "evalPrompt": "/aigon-feature-eval {featureId}",
    "reviewPrompt": "/aigon-feature-code-review {featureId}",
    "reviewCheckPrompt": "/aigon-feature-code-revise {featureId}",
    "models": {
      "review": "composer-2.5"
    },
