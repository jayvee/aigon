; Refuse to install any package version published in the last 3 days.
; Defence against npm supply-chain worms (e.g. chalk/debug Sept 2025, Shai-Hulud)
; that typically get caught and unpublished within hours/days. Applies to fresh
; installs and `npm update` / new deps — does not affect versions already pinned
; in package-lock.json. Requires npm >= 11.5.1. Value is in days.
min-release-age=3
