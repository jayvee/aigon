# Node
node_modules/

# OS
.DS_Store

# Screenshots / dev artifacts at repo root — keep these in
# site/public/img/ or docs/images/ instead. Subdirectories are unaffected.
/*.png
/*.jpg
/*.jpeg

# CleanShot X exports — never commit (any path, any case)
**/*CleanShot*
**/*cleanshot*

# Environment (secrets, per-machine config)
.env.local
.env*.local

# Playwright
playwright-report/
test-results/
tests/dashboard-e2e/screenshots/
.playwright-mcp/

# Aigon runtime files (never committed)
.aigon/state/
.aigon/sessions/
.aigon/locks/
.aigon/workflows/
.aigon/telemetry/
.aigon/worktree.json
.aigon/.board-map.json
.aigon/cache/
.aigon/migrations/
.aigon/recurring-state.json
.aigon/server/
next-env.d.ts

# Agent config files — generated by `aigon install-agent`
# These are machine-specific outputs; source of truth is templates/
.claude/commands/
.claude/settings.json
.claude/settings.local.json
.claude/skills/
.claude/projects/
.gemini/
.codex/
.cursor/
.agents/

# Scratch — agent-referenced files that shouldn't ship (screenshots, local tarballs, etc.)
tmp/

# Promotional GIF workflow
docs/media/raw/

# Site (future Next.js)
site/node_modules/
site/.next/
site/.env.local
site/.env*.local
site/out/
site/.vercel/
.aigon/insights-cache.json
.aigon/budget-cache.json
.vercel

# Security scan ephemeral output
.scan/reports/
.scan/raw/
