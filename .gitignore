# Node
node_modules/

# OS
.DS_Store

# Screenshots / dev artifacts at repo root — keep these in
# site/public/img/ or docs/images/ instead. Subdirectories are unaffected.
/*.png
/*.jpg
/*.jpeg

# CleanShot X exports — never commit (any path, any case)
**/*CleanShot*
**/*cleanshot*

# Environment (secrets, per-machine config)
.env.local
.env*.local

# Playwright
playwright-report/
test-results/
tests/dashboard-e2e/screenshots/
.playwright-mcp/

# Aigon runtime files (never committed)
.aigon/state/
.aigon/sessions/
.aigon/locks/
.aigon/workflows/
.aigon/telemetry/
.aigon/worktree.json
.aigon/.board-map.json
.aigon/cache/
.aigon/migrations/
.aigon/recurring-state.json
.aigon/server/
next-env.d.ts

# Agent config files — generated by `aigon install-agent`
# These are machine-specific outputs; source of truth is templates/
# Exception: aigon-repo contributor slash commands (start-docs, seed-reset,
# restart-server) are committed directly as ordinary repo files — they live
# inside otherwise-generated agent dirs, so each agent dir has explicit
# `!`-exceptions below.
.claude/commands/*
!.claude/commands/start-docs.md
!.claude/commands/seed-reset.md
!.claude/commands/restart-server.md
.claude/settings.json
.claude/settings.local.json
.claude/skills/*
!.claude/skills/release/
.claude/projects/
.gemini/*
!.gemini/commands/
.gemini/commands/*
!.gemini/commands/start-docs.toml
!.gemini/commands/seed-reset.toml
!.gemini/commands/restart-server.toml
.codex/
.cursor/*
!.cursor/start-docs.md
!.cursor/seed-reset.md
!.cursor/restart-server.md
.agents/*
!.agents/skills/
.agents/skills/*
!.agents/skills/start-docs/
!.agents/skills/seed-reset/
!.agents/skills/restart-server/

# Scratch — agent-referenced files that shouldn't ship (screenshots, local tarballs, etc.)
tmp/

# Promotional GIF workflow
docs/media/raw/

# Site (future Next.js)
site/node_modules/
site/.next/
site/.env.local
site/.env*.local
site/out/
site/.vercel/
.aigon/insights-cache.json
.aigon/budget-cache.json
.vercel

# Security scan ephemeral output
.scan/reports/
.scan/raw/

# Recurring feature reports — contain user/fleet-specific data, never commit
docs/reports/
.aigon/reports/

# E2E test forensics log — written on every run, inspect locally
docker/clean-room/last-run.log

# npm pack output — local build artefact, never commit
senlabsai-aigon-*.tgz
senlabs-aigon-*.tgz

# Regenerated by every `aigon apply` against this repo (F497). Tracked
# in user repos as provenance, but in the aigon source repo it's a
# constantly-shifting local artefact that dirties the working tree
# between ship runs.
.aigon/applied-digest
