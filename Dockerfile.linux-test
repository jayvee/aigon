FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

# Minimal base — just what a fresh Ubuntu has plus node/git/tmux
RUN apt-get update && apt-get install -y \
    curl \
    git \
    tmux \
    sudo \
    && rm -rf /var/lib/apt/lists/*

# Node.js 22
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# Create a regular user (simulates a real dev machine)
RUN useradd -m -s /bin/bash dev && echo "dev:dev" | chpasswd && adduser dev sudo
USER dev
WORKDIR /home/dev

# Minimal git config
RUN git config --global user.name "Dev User" \
    && git config --global user.email "dev@example.com" \
    && git config --global init.defaultBranch main

EXPOSE 4100

CMD ["bash"]
