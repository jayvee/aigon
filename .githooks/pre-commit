#!/bin/sh
# Pre-commit guardrails for the aigon repo.
#
# Blocks four classes of leak:
#   1. .env / .env.*.local files (never commit envs)
#   2. The known-leaked Pro beta key (`aigon-pro-beta-2026`) — kept here as a
#      historical sentinel even after rotation; any reappearance is a regression
#   3. Filenames that belong only in aigon-pro (`*published-pro*`, `pro-test-*`)
#   4. Non-placeholder values of AIGON_PRO_KEY=…
#
# Override (single-commit only) by exporting AIGON_ALLOW_SENSITIVE_COMMIT=1.
# This exists so a maintainer who genuinely needs to commit a scrubbing fix
# inside the secret-pattern file itself can do it without disabling the hook.

set -eu

STAGED_FILES="$(git diff --cached --name-only --diff-filter=ACMR || true)"
FAIL=0

# ── 1. .env files ────────────────────────────────────────────────────────────
ENV_HITS="$(printf '%s\n' "$STAGED_FILES" | grep -E '(^|/)\.env$|(^|/)\.env(\..+)?\.local$' || true)"
if [ -n "$ENV_HITS" ]; then
  echo "ERROR: Refusing to commit environment files that may contain secrets."
  echo "$ENV_HITS"
  echo "  Remove with: git reset HEAD <file>"
  FAIL=1
fi

# ── 2. Pro/internal-only filenames in the public OSS repo ────────────────────
PRO_FILE_HITS="$(printf '%s\n' "$STAGED_FILES" | grep -E '(^|/)(.*published-pro|pro-test-[^/]+|.*-pro-key.*|aigon-pro-config\.json)$' || true)"
if [ -n "$PRO_FILE_HITS" ]; then
  echo "ERROR: Filenames that look Pro-internal are staged in the public aigon repo:"
  echo "$PRO_FILE_HITS"
  echo "  Pro-related test infra and credentials belong in ~/src/aigon-pro/, not here."
  echo "  Move the file there, or rename if this is a false positive."
  FAIL=1
fi

# ── 3. Diff content — known-leaked key + AIGON_PRO_KEY= literals ─────────────
# Grep the staged diff (additions only) for sentinel patterns.
DIFF_PATCH="$(git diff --cached --diff-filter=ACMR -U0 || true)"
SECRET_HITS=""

# Known leaked beta key (historical sentinel — regression detector)
if printf '%s' "$DIFF_PATCH" | grep -E '^\+' | grep -q 'aigon-pro-beta-2026'; then
  SECRET_HITS="${SECRET_HITS}- found 'aigon-pro-beta-2026' (the leaked-and-rotated Pro beta key) in a staged addition
"
fi

# Any AIGON_PRO_KEY=<value> where <value> isn't a placeholder
# Placeholders allowed: <…>, $VAR, ${VAR}, "", '', or an env-ref. Anything else fails.
NONPLACEHOLDER_KEY="$(printf '%s' "$DIFF_PATCH" \
  | grep -E '^\+' \
  | grep -oE 'AIGON_PRO_KEY=[^[:space:]"'"'"']+' \
  | grep -vE 'AIGON_PRO_KEY=(<[^>]+>|\$\{?AIGON_PRO_KEY\}?|\$\{?[A-Z_]+\}?|""|'"'"''"'"'|\$1|\$@)' || true)"
if [ -n "$NONPLACEHOLDER_KEY" ]; then
  SECRET_HITS="${SECRET_HITS}- AIGON_PRO_KEY= with a non-placeholder value in a staged addition:
$(printf '%s' "$NONPLACEHOLDER_KEY" | sed 's/^/    /')
"
fi

if [ -n "$SECRET_HITS" ]; then
  printf 'ERROR: secret-pattern guardrail blocked this commit:\n%s' "$SECRET_HITS"
  echo
  echo "  - If this is a real credential: do not commit it. Move it to aigon-pro/"
  echo "    or read it from an environment variable at runtime."
  echo "  - If this is a placeholder, use one of: <your-key>, \$AIGON_PRO_KEY,"
  echo "    \${AIGON_PRO_KEY}, or leave the value empty."
  echo "  - To override for one commit (e.g. updating the hook itself):"
  echo "      AIGON_ALLOW_SENSITIVE_COMMIT=1 git commit ..."
  FAIL=1
fi

# ── Final exit ───────────────────────────────────────────────────────────────
if [ "$FAIL" -ne 0 ]; then
  if [ "${AIGON_ALLOW_SENSITIVE_COMMIT:-0}" = "1" ]; then
    echo
    echo "  AIGON_ALLOW_SENSITIVE_COMMIT=1 set — proceeding anyway."
    exit 0
  fi
  exit 1
fi

exit 0
