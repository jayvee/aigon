#!/bin/sh
set -eu

STAGED_FILES="$(git diff --cached --name-only --diff-filter=ACMR || true)"
BLOCKED_FILES="$(printf '%s\n' "$STAGED_FILES" | grep -E '(^|/)\.env$|(^|/)\.env(\..+)?\.local$' || true)"

if [ -n "$BLOCKED_FILES" ]; then
  echo ""
  echo "BLOCKED: Attempting to commit environment file(s) with secrets:"
  echo ""
  printf '%s\n' "$BLOCKED_FILES" | while read -r file; do
    echo "   - $file"
  done
  echo ""
  echo "Remove from staging with: git reset HEAD <file>"
  echo "To bypass (not recommended): git commit --no-verify"
  echo ""
  exit 1
fi

# Secret scanning via gitleaks (if installed)
if command -v gitleaks >/dev/null 2>&1; then
  gitleaks protect --staged --exit-code 1 --no-banner 2>&1
  if [ $? -ne 0 ]; then
    echo ""
    echo "To bypass (not recommended): git commit --no-verify"
    echo ""
    exit 1
  fi
fi

exit 0
