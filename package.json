{
  "name": "aigon",
  "version": "2.50.23",
  "description": "CLI for the Aigon Spec-Driven AI Dev Flow",
  "bin": {
    "aigon": "./aigon-cli.js"
  },
  "scripts": {
    "test": "node aigon-cli.test.js && node lib/manifest.test.js && node lib/workflow-core/workflow-core.test.js && node lib/workflow-close.test.js && node lib/workflow-start.test.js && node lib/workflow-eval.test.js && node lib/workflow-signals.test.js && npx playwright test --config tests/dashboard/playwright.config.js --reporter=list",
    "test:dashboard": "npx playwright test --config tests/dashboard/playwright.config.js --reporter=list",
    "test:e2e": "node test/e2e.test.js",
    "test:e2e:mock-solo": "node test/e2e-mock-solo.test.js",
    "test:e2e:mock-fleet": "node test/e2e-mock-fleet.test.js",
    "test:dashboard:e2e": "npx playwright test --config tests/dashboard-e2e/playwright.config.js --reporter=list",
    "test:dashboard:api": "node --test test/dashboard-e2e.test.js",
    "test:dashboard:agents": "node --test test/dashboard-e2e-agents.test.js",
    "test:dashboard:agents:features": "node --test test/dashboard-e2e-agents.test.js --test-name-pattern='Feature'",
    "test:dashboard:agents:research": "node --test test/dashboard-e2e-research.test.js",
    "test:all": "node aigon-cli.test.js && node test/e2e.test.js",
    "fixture:seed": "node test/setup-fixture.js",
    "fixture:reset": "node test/reset-fixture.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "http-proxy": "^1.18.1",
    "xstate": "^5.30.0"
  }
}
