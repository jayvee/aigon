{
  "name": "@senlabsai/aigon",
  "version": "2.74.13",
  "description": "CLI for the Aigon Spec-Driven AI Dev Flow",
  "packageManager": "npm@11.14.1",
  "license": "Apache-2.0",
  "author": "Sen Labs (https://senlabs.ai)",
  "homepage": "https://www.aigon.build",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jayvee/aigon.git"
  },
  "bugs": {
    "url": "https://github.com/jayvee/aigon/issues"
  },
  "keywords": [
    "ai-agents",
    "claude-code",
    "gemini-cli",
    "codex",
    "cli",
    "multi-agent",
    "spec-driven",
    "agent-orchestration",
    "developer-tools",
    "workflow-engine"
  ],
  "files": [
    "aigon-cli.js",
    "lib",
    "templates",
    "assets/icon",
    "scripts/fix-node-pty-perms.js",
    "scripts/probe-agent.js",
    "scripts/check-package-security-config.js",
    "scripts/check-suspicious-deps.js"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "aigon": "aigon-cli.js"
  },
  "scripts": {
    "postinstall": "node ./aigon-cli.js global-setup --non-interactive --quiet || true && node scripts/fix-node-pty-perms.js || true && node ./aigon-cli.js installed-notice || true",
    "prepublishOnly": "node scripts/check-root-instruction-budget.js && node scripts/check-template-leaks.js && node scripts/check-rendered-template-leaks.js && node scripts/check-install-manifest-clean.js && node scripts/check-pack.js",
    "release": "node scripts/publish.js",
    "ship": "node scripts/ship.js",
    "ship:share": "node scripts/ship.js share",
    "ship:cut": "node scripts/ship.js cut",
    "ship:publish": "node scripts/ship.js publish",
    "lint": "eslint \"lib/**/*.js\" \"templates/dashboard/js/**/*.js\" tests/unit tests/integration tests/workflow-core",
    "lint:paths": "node scripts/check-path-literals.js",
    "test": "npm run test:core",
    "test:unit": "node scripts/run-tests-parallel.js \"tests/unit/*.test.js\" --exclude=\"tests/unit/git-branch-backend.test.js\" --exclude=\"tests/unit/spec-store-leases.test.js\" --exclude=\"tests/unit/storage-convert.test.js\"",
    "test:unit:heavy": "node scripts/run-tests-parallel.js \"tests/unit/git-branch-backend.test.js\" \"tests/unit/spec-store-leases.test.js\" \"tests/unit/storage-convert.test.js\"",
    "test:integration": "node scripts/run-tests-parallel.js \"tests/integration/*.test.js\" --exclude=\"tests/integration/agent-failover-end-to-end.test.js\" --exclude=\"tests/integration/agent-quota-poller.test.js\" --exclude=\"tests/integration/agent-registry-contract.test.js\" --exclude=\"tests/integration/apply-bootstrap.test.js\" --exclude=\"tests/integration/awaiting-input-dashboard.test.js\" --exclude=\"tests/integration/bootstrap-engine-state.test.js\" --exclude=\"tests/integration/dashboard-commits-route.test.js\" --exclude=\"tests/integration/dashboard-fs-watch.test.js\" --exclude=\"tests/integration/dashboard-perf-lean-done.test.js\" --exclude=\"tests/integration/dashboard-review-statuses.test.js\" --exclude=\"tests/integration/feature-close-autostash-recovery.test.js\" --exclude=\"tests/integration/feature-close-post-merge-gate.test.js\" --exclude=\"tests/integration/feature-close-preauth-validation.test.js\" --exclude=\"tests/integration/feature-set-spec-review.test.js\" --exclude=\"tests/integration/feature-set-spec-revise.test.js\" --exclude=\"tests/integration/git-branch-observability.test.js\" --exclude=\"tests/integration/git-branch-reset-sync.test.js\" --exclude=\"tests/integration/install-agent.test.js\" --exclude=\"tests/integration/lifecycle-source-deletion.test.js\" --exclude=\"tests/integration/lifecycle.test.js\" --exclude=\"tests/integration/prioritise-dep-validate.test.js\" --exclude=\"tests/integration/security-scan-feature-filing.test.js\" --exclude=\"tests/integration/spec-layout-migration.test.js\" --exclude=\"tests/integration/submit-signal-loss.test.js\" --exclude=\"tests/integration/two-clone-git-branch-storage.test.js\"",
    "test:integration:heavy": "node scripts/run-tests-parallel.js \"tests/integration/agent-failover-end-to-end.test.js\" \"tests/integration/agent-quota-poller.test.js\" \"tests/integration/agent-registry-contract.test.js\" \"tests/integration/apply-bootstrap.test.js\" \"tests/integration/awaiting-input-dashboard.test.js\" \"tests/integration/bootstrap-engine-state.test.js\" \"tests/integration/dashboard-commits-route.test.js\" \"tests/integration/dashboard-fs-watch.test.js\" \"tests/integration/dashboard-perf-lean-done.test.js\" \"tests/integration/dashboard-review-statuses.test.js\" \"tests/integration/feature-close-autostash-recovery.test.js\" \"tests/integration/feature-close-post-merge-gate.test.js\" \"tests/integration/feature-close-preauth-validation.test.js\" \"tests/integration/feature-set-spec-review.test.js\" \"tests/integration/feature-set-spec-revise.test.js\" \"tests/integration/git-branch-observability.test.js\" \"tests/integration/git-branch-reset-sync.test.js\" \"tests/integration/install-agent.test.js\" \"tests/integration/lifecycle-source-deletion.test.js\" \"tests/integration/lifecycle.test.js\" \"tests/integration/prioritise-dep-validate.test.js\" \"tests/integration/security-scan-feature-filing.test.js\" \"tests/integration/spec-layout-migration.test.js\" \"tests/integration/submit-signal-loss.test.js\" \"tests/integration/two-clone-git-branch-storage.test.js\"",
    "test:workflow": "node scripts/run-tests-parallel.js \"tests/workflow-core/*.test.js\"",
    "test:migration": "bash scripts/test-brewboard-migration.sh",
    "test:iterate": "node scripts/iterate-validate.js",
    "test:quick": "npm run test:iterate",
    "test:related": "node scripts/test-related.js",
    "test:core": "npm run lint:paths && npm run lint && node scripts/check-root-instruction-budget.js && node scripts/check-template-leaks.js && node scripts/check-module-graph.js && node scripts/check-alpine-bindings.js && node scripts/generate-workflow-diagrams.js --check && bash scripts/check-test-budget.sh && npm run test:unit && npm run test:integration && npm run test:workflow",
    "test:core:full": "npm run test:core && npm run test:unit:heavy && npm run test:integration:heavy",
    "test:browser": "npm run test:browser:smoke",
    "test:browser:full": "MOCK_DELAY=fast npx playwright test --config tests/dashboard-e2e/playwright.config.js --reporter=list",
    "test:browser:live": "node -e \"if(process.env.AIGON_E2E_REAL!=='1'){console.error('Set AIGON_E2E_REAL=1 to run the opt-in live-agent smoke path');process.exit(1)}\" && MOCK_DELAY=fast npx playwright test --config tests/dashboard-e2e/playwright.live.config.js --reporter=list",
    "test:browser:smoke": "MOCK_DELAY=fast npx playwright test --config tests/dashboard-e2e/playwright.config.js --reporter=list --grep @smoke",
    "test:deploy": "npm run test:core && npm run test:browser:smoke && bash scripts/check-test-budget.sh",
    "test:release": "npm run test:core:full && npm run security:package-config && npm run security:suspicious-deps && npm audit --omit=dev --audit-level=high && npm run test:browser:full && bash scripts/check-test-budget.sh",
    "test:ui": "npm run test:browser:smoke",
    "test:all": "npm run test:release",
    "gallery": "node scripts/start-dashboard-gallery.js",
    "test:gallery": "npx playwright test --config tests/gallery-e2e/playwright.config.js",
    "fixture:seed": "node scripts/setup-fixture.js",
    "fixture:reset": "node scripts/reset-fixture.js",
    "security:package-config": "node scripts/check-package-security-config.js",
    "security:suspicious-deps": "node scripts/check-suspicious-deps.js",
    "workflow:diagrams": "node scripts/generate-workflow-diagrams.js",
    "workflow:diagrams:check": "node scripts/generate-workflow-diagrams.js --check"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "eslint": "^9.38.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "node-pty": "npm:@homebridge/node-pty-prebuilt-multiarch@^0.13.1",
    "ws": "^8.21.0",
    "xstate": "^5.30.0"
  }
}
