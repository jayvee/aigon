{
  "name": "@aigon/cli",
  "version": "2.54.6",
  "description": "CLI for the Aigon Spec-Driven AI Dev Flow",
  "license": "Apache-2.0",
  "author": "Sen Labs (https://senlabs.ai)",
  "homepage": "https://www.aigon.build",
  "repository": {
    "type": "git",
    "url": "https://github.com/jayvee/aigon.git"
  },
  "bugs": {
    "url": "https://github.com/jayvee/aigon/issues"
  },
  "keywords": [
    "ai-agents",
    "claude-code",
    "gemini-cli",
    "codex",
    "cli",
    "multi-agent",
    "spec-driven",
    "agent-orchestration",
    "developer-tools",
    "workflow-engine"
  ],
  "files": [
    "aigon-cli.js",
    "lib",
    "templates",
    "assets/icon"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "aigon": "./aigon-cli.js"
  },
  "scripts": {
    "postinstall": "node ./aigon-cli.js global-setup --non-interactive --quiet || true && node scripts/fix-node-pty-perms.js || true",
    "prepublishOnly": "node scripts/check-pack.js",
    "release": "node scripts/publish.js",
    "lint": "eslint \"lib/**/*.js\" tests/integration tests/workflow-core",
    "test": "npm run lint && node scripts/generate-workflow-diagrams.js --check && npm run test:integration && npm run test:workflow",
    "test:integration": "for f in tests/integration/*.test.js; do echo \"--- $f ---\" && node \"$f\" || exit 1; done",
    "test:workflow": "for f in tests/workflow-core/*.test.js; do echo \"--- $f ---\" && node \"$f\" || exit 1; done",
    "test:ui": "npx playwright test --config tests/dashboard-e2e/playwright.config.js --reporter=list",
    "test:all": "npm test && npm run test:ui",
    "fixture:seed": "node scripts/setup-fixture.js",
    "fixture:reset": "node scripts/reset-fixture.js",
    "workflow:diagrams": "node scripts/generate-workflow-diagrams.js",
    "workflow:diagrams:check": "node scripts/generate-workflow-diagrams.js --check"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "eslint": "^9.38.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "node-pty": "^1.1.0",
    "ws": "^8.20.0",
    "xstate": "^5.30.0"
  }
}
