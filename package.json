{
  "name": "aigon",
  "version": "2.50.23",
  "description": "CLI for the Aigon Spec-Driven AI Dev Flow",
  "bin": {
    "aigon": "./aigon-cli.js"
  },
  "scripts": {
    "test": "node scripts/generate-workflow-diagrams.js --check && node tests/run-unit.js && node tests/integration/lifecycle.test.js",
    "test:integration": "node tests/integration/e2e.test.js",
    "test:integration:mock-solo": "node tests/integration/e2e-mock-solo.test.js",
    "test:integration:mock-fleet": "node tests/integration/e2e-mock-fleet.test.js",
    "test:api": "node tests/api/status-actions.test.js",
    "test:api:agents": "node --test tests/api/dashboard-e2e-agents.test.js",
    "test:api:research": "node --test tests/api/dashboard-e2e-research.test.js",
    "test:ui": "npx playwright test --config tests/dashboard/playwright.config.js --reporter=list && npx playwright test --config tests/dashboard-e2e/playwright.config.js --reporter=list",
    "test:ui:dashboard": "npx playwright test --config tests/dashboard/playwright.config.js --reporter=list",
    "test:ui:lifecycle": "npx playwright test --config tests/dashboard-e2e/playwright.config.js --reporter=list",
    "test:all": "npm test && npm run test:api && npm run test:ui",
    "fixture:seed": "node test/setup-fixture.js",
    "fixture:reset": "node test/reset-fixture.js",
    "workflow:diagrams": "node scripts/generate-workflow-diagrams.js",
    "workflow:diagrams:check": "node scripts/generate-workflow-diagrams.js --check"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "http-proxy": "^1.18.1",
    "xstate": "^5.30.0"
  }
}
