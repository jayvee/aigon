{
  "name": "aigon",
  "version": "2.50.0",
  "description": "CLI for the Aigon Spec-Driven AI Dev Flow",
  "bin": {
    "aigon": "./aigon-cli.js"
  },
  "scripts": {
    "test": "node aigon-cli.test.js && npx playwright test --config tests/dashboard/playwright.config.js --reporter=list",
    "test:dashboard": "npx playwright test --config tests/dashboard/playwright.config.js --reporter=list",
    "test:e2e": "node test/e2e.test.js",
    "test:e2e:mock-solo": "node test/e2e-mock-solo.test.js",
    "test:e2e:mock-fleet": "node test/e2e-mock-fleet.test.js",
    "test:dashboard:e2e": "npx playwright test --config tests/dashboard-e2e/playwright.config.js --reporter=list",
    "test:all": "node aigon-cli.test.js && node test/e2e.test.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2"
  },
  "dependencies": {
    "http-proxy": "^1.18.1"
  }
}
