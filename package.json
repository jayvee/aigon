{
  "name": "aigon",
  "version": "2.50.38",
  "description": "CLI for the Aigon Spec-Driven AI Dev Flow",
  "bin": {
    "aigon": "./aigon-cli.js"
  },
  "scripts": {
    "test": "node scripts/generate-workflow-diagrams.js --check && node tests/integration/lifecycle.test.js && node tests/integration/landing-home-check.test.js",
    "test:ui": "npx playwright test --config tests/dashboard-e2e/playwright.config.js --reporter=list",
    "test:landing": "npx playwright test --config tests/landing/playwright.config.js --reporter=list",
    "test:all": "npm test && npm run test:ui && npm run test:landing",
    "fixture:seed": "node scripts/setup-fixture.js",
    "fixture:reset": "node scripts/reset-fixture.js",
    "workflow:diagrams": "node scripts/generate-workflow-diagrams.js",
    "workflow:diagrams:check": "node scripts/generate-workflow-diagrams.js --check"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "http-proxy": "^1.18.1",
    "xstate": "^5.30.0"
  }
}
