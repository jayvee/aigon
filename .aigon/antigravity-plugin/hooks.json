{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "aigon check-version --notice-only",
            "timeout": 15000
          },
          {
            "type": "command",
            "command": "aigon project-context --json",
            "timeout": 10000
          }
        ]
      }
    ],
    "AfterAgent": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "aigon check-agent-signal --json",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "aigon capture-antigravity-telemetry",
            "timeout": 15000
          }
        ]
      }
    ]
  }
}
