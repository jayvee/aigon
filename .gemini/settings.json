{
  "tools": {
    "allowed": [
      "aigon"
    ]
  },
  "_aigon": {
    "note": "Tools added by Aigon",
    "tools": [
      "aigon"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/aigon check-version",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "/opt/homebrew/bin/aigon project-context",
            "timeout": 10
          }
        ]
      }
    ],
    "AfterAgent": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/jviner/.local/state/fnm_multishells/55802_1774936958876/bin/aigon check-agent-signal",
            "timeout": 5
          }
        ]
      }
    ]
  }
}